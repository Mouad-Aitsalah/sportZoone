generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoleUtilisateur {
  SUPER_ADMIN
  ADMIN_GLOBAL
  ADMIN
  EMPLOYE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CompteType {
  CLIENT
  FOURNISSEUR
}

enum StockMovementType {
  IN
  CORRECTION
  SALE
  CANCEL
  RETURN
  PURCHASE
  SUPPLIER_RETURN
}

enum AchatModeReglement {
  ESPECE
  CHEQUE
  CREDIT
}

enum AchatStatut {
  ENREGISTRE
  PAYE
  CREDIT_EN_ATTENTE
}

enum AvoirStatut {
  ENREGISTRE
  REMBOURSE
  ANNULE
}

enum AvoirFournisseurStatut {
  BROUILLON
  VALIDE
  REMBOURSE
  ANNULE
}

enum CompensationMode {
  REMBOURSEMENT
  AVOIR_PROCHAINE_FACTURE
  REMPLACEMENT_PRODUIT
}

enum SessionCaisseStatut {
  OUVERTE
  FERMEE
}

enum ChargeCategorie {
  ELECTRICITE
  EAU
  LOYER
  REPARATION
  TRANSPORT
  CARBURANT
  INTERNET
  SALAIRE
  AUTRE
}

enum ChargeModePaiement {
  ESPECE
  CARTE
  VIREMENT
  CHEQUE
  AUTRE
}

model Organisation {
  id                    String                 @id @default(cuid())
  name                  String                 @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  utilisateurs          Utilisateur[]
  loginApprovalRequests LoginApprovalRequest[]
  pointsDeVente         PointDeVente[]
  caisses               Caisse[]
  comptes               Compte[]
  categoriesProduit     CategorieProduit[]
  fournisseurs          Fournisseur[]
  produits              Produit[]
  produitVariantes      ProduitVariante[]
  clients               Client[]
  paiementsClient       PaiementClient[]
  stocks                Stock[]
  stockMovements        StockMovement[]
  achats                Achat[]
  achatLignes           AchatLigne[]
  avoirs                Avoir[]
  avoirLignes           AvoirLigne[]
  avoirsFournisseur     AvoirFournisseur[]
  avoirFournisseurLignes AvoirFournisseurLigne[]
  sessionsCaisse        SessionCaisse[]
  ventes                Vente[]
  lignesVente           VenteLigne[]
  retours               Retour[]
  charges               Charge[]
}

model CategorieProduit {
  id             Int          @id @default(autoincrement())
  organisationId String
  code           String
  nom            String
  nomComplet     String
  actif          Boolean      @default(true)
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  produits       Produit[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organisationId, code])
  @@unique([organisationId, nom])
  @@index([organisationId])
  @@index([actif])
  @@index([organisationId, actif])
}

model PointDeVente {
  id             Int             @id @default(autoincrement())
  organisationId String
  nom            String
  adresse        String?
  telephone      String?
  organisation   Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  utilisateurs   Utilisateur[]
  caisses        Caisse[]
  stocks         Stock[]
  stockMovements StockMovement[]
  achats         Achat[]
  avoirs         Avoir[]
  avoirsFournisseur AvoirFournisseur[]
  sessionsCaisse SessionCaisse[]
  ventes         Vente[]
  charges        Charge[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organisationId])
}

model Utilisateur {
  id                    Int                    @id @default(autoincrement())
  organisationId        String
  nom                   String
  email                 String                 @unique
  motDePasse            String
  role                  RoleUtilisateur        @default(EMPLOYE)
  estActif              Boolean                @default(true)
  approvalStatus        ApprovalStatus         @default(PENDING)
  organisation          Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  pointDeVenteId        Int?
  pointDeVente          PointDeVente?          @relation(fields: [pointDeVenteId], references: [id])
  caisseId              Int?
  caisse                Caisse?                @relation(fields: [caisseId], references: [id])
  sessionsCaisse        SessionCaisse[]
  ventes                Vente[]
  charges               Charge[]
  loginApprovalRequests LoginApprovalRequest[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([organisationId])
  @@index([pointDeVenteId])
  @@index([caisseId])
  @@index([approvalStatus])
}

model LoginApprovalRequest {
  id         Int            @id @default(autoincrement())
  organisationId String
  userId     Int
  email      String
  status     ApprovalStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  approvedAt DateTime?
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user       Utilisateur    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organisationId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Caisse {
  id             Int           @id @default(autoincrement())
  organisationId String
  nom            String
  code           String
  pointDeVenteId Int
  estActive      Boolean       @default(true)
  organisation   Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  pointDeVente   PointDeVente  @relation(fields: [pointDeVenteId], references: [id], onDelete: Cascade)
  utilisateurs   Utilisateur[]
  sessionsCaisse SessionCaisse[]
  ventes         Vente[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organisationId, code])
  @@unique([pointDeVenteId, nom])
  @@index([organisationId])
  @@index([pointDeVenteId])
  @@index([estActive])
}

model Fournisseur {
  id             Int           @id @default(autoincrement())
  organisationId String
  nom            String
  email          String?
  telephone      String?
  adresse        String?
  organisation   Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  compte         Compte?       @relation("FournisseurCompte")
  achats         Achat[]
  produits       Produit[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organisationId, email])
  @@index([organisationId])
}

model Produit {
  id             Int             @id @default(autoincrement())
  organisationId String
  codeBarres     String?
  nom            String
  categorie      String
  categorieId    Int
  prixAchat      Decimal         @db.Decimal(10, 2)
  prixVente      Decimal         @db.Decimal(10, 2)
  tauxTVA        Decimal         @default(0) @db.Decimal(5, 2)
  prixDetail     Decimal         @default(0) @db.Decimal(10, 2)
  prixGros       Decimal         @default(0) @db.Decimal(10, 2)
  prixMiniGros   Decimal         @default(0) @db.Decimal(10, 2)
  seuilMinimum   Int             @default(0)
  estActif       Boolean         @default(true)
  fournisseurId  Int?
  organisation   Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  categorieProduit CategorieProduit @relation(fields: [categorieId], references: [id])
  fournisseur    Fournisseur?    @relation(fields: [fournisseurId], references: [id])
  variantes      ProduitVariante[]
  achatLignes    AchatLigne[]
  stocks         Stock[]
  stockMovements StockMovement[]
  lignesVente    VenteLigne[]
  retours        Retour[]
  avoirLignes    AvoirLigne[]
  avoirFournisseurLignes AvoirFournisseurLigne[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([organisationId, codeBarres])
  @@index([organisationId])
  @@index([categorie])
  @@index([categorieId])
  @@index([fournisseurId])
  @@index([organisationId, nom])
  @@index([organisationId, categorieId])
}

model ProduitVariante {
  id             Int             @id @default(autoincrement())
  organisationId String
  produitId      Int
  taille         String?
  couleur        String?
  valeursVariante String?
  codeBarres     String?
  prixAchat      Decimal?        @db.Decimal(10, 2)
  prixVente      Decimal?        @db.Decimal(10, 2)
  quantiteStock  Float           @default(0)
  seuilMinimum   Int             @default(0)
  actif          Boolean         @default(true)
  organisation   Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  produit        Produit         @relation(fields: [produitId], references: [id], onDelete: Cascade)
  achatLignes    AchatLigne[]
  lignesVente    VenteLigne[]
  retours        Retour[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([organisationId, codeBarres])
  @@index([organisationId])
  @@index([produitId])
  @@index([actif])
}

model Client {
  id             Int              @id @default(autoincrement())
  organisationId String
  numeroClient   Int
  nom            String
  telephone      String?
  email          String?
  credit         Decimal          @default(0) @db.Decimal(10, 2)
  estActif       Boolean          @default(true)
  organisation   Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  compte         Compte?          @relation("ClientCompte")
  ventes         Vente[]
  paiements      PaiementClient[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organisationId, numeroClient])
  @@index([organisationId])
  @@index([nom])
  @@index([estActif])
}

model Compte {
  id                  Int          @id @default(autoincrement())
  organisationId      String
  numeroCompte        String
  type                CompteType
  nom                 String
  telephone           String?
  email               String?
  adresse             String?
  actif               Boolean      @default(true)
  clientSourceId      Int?         @unique
  fournisseurSourceId Int?         @unique
  organisation        Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  clientSource        Client?      @relation("ClientCompte", fields: [clientSourceId], references: [id], onDelete: SetNull)
  fournisseurSource   Fournisseur? @relation("FournisseurCompte", fields: [fournisseurSourceId], references: [id], onDelete: SetNull)
  achatsFournisseur   Achat[]      @relation("AchatCompteFournisseur")
  avoirsClient        Avoir[]      @relation("AvoirCompteClient")
  avoirsFournisseur   AvoirFournisseur[] @relation("AvoirFournisseurCompte")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([organisationId, numeroCompte])
  @@index([organisationId])
  @@index([type])
  @@index([nom])
}

model PaiementClient {
  id             Int          @id @default(autoincrement())
  organisationId String
  clientId       Int
  montant        Decimal      @db.Decimal(10, 2)
  note           String?
  createdAt      DateTime     @default(now())
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organisationId])
  @@index([clientId])
  @@index([createdAt])
}

model Stock {
  id             Int          @id @default(autoincrement())
  organisationId String
  produitId      Int
  pointDeVenteId Int
  quantite       Float        @default(0)
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  produit        Produit      @relation(fields: [produitId], references: [id], onDelete: Cascade)
  pointDeVente   PointDeVente @relation(fields: [pointDeVenteId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organisationId, produitId, pointDeVenteId])
  @@index([organisationId])
  @@index([produitId])
  @@index([pointDeVenteId])
}

model StockMovement {
  id             Int               @id @default(autoincrement())
  organisationId String
  produitId      Int
  pointDeVenteId Int
  quantite       Float
  type           StockMovementType
  reason         String?
  createdAt      DateTime          @default(now())
  organisation   Organisation      @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  produit        Produit           @relation(fields: [produitId], references: [id], onDelete: Cascade)
  pointDeVente   PointDeVente      @relation(fields: [pointDeVenteId], references: [id], onDelete: Cascade)

  @@index([organisationId])
  @@index([produitId])
  @@index([pointDeVenteId])
  @@index([type])
  @@index([createdAt])
}

model SessionCaisse {
  id             Int                 @id @default(autoincrement())
  organisationId String
  numeroSession  String
  caisseId       Int
  pointDeVenteId Int
  utilisateurId  Int
  dateOuverture  DateTime            @default(now())
  dateFermeture  DateTime?
  statut         SessionCaisseStatut @default(OUVERTE)
  totalVentes    Decimal             @default(0) @db.Decimal(10, 2)
  nombreTickets  Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organisation   Organisation        @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  caisse         Caisse              @relation(fields: [caisseId], references: [id])
  pointDeVente   PointDeVente        @relation(fields: [pointDeVenteId], references: [id])
  utilisateur    Utilisateur         @relation(fields: [utilisateurId], references: [id])
  ventes         Vente[]

  @@unique([organisationId, numeroSession])
  @@index([organisationId])
  @@index([caisseId])
  @@index([pointDeVenteId])
  @@index([utilisateurId])
  @@index([statut])
  @@index([dateOuverture])
}

model Vente {
  id             Int          @id @default(autoincrement())
  organisationId String
  numeroTicket   String       @unique
  total          Decimal      @db.Decimal(10, 2)
  paymentMethod  String       @default("cash")
  paidAmount     Decimal      @default(0) @db.Decimal(10, 2)
  remainingAmount Decimal     @default(0) @db.Decimal(10, 2)
  paymentStatus  String       @default("PAID")
  status         String       @default("completed")
  dateVente      DateTime     @default(now())
  pointDeVenteId Int
  caisseId       Int
  utilisateurId  Int
  clientId       Int?
  originalSaleId Int?
  sessionCaisseId Int?
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  pointDeVente   PointDeVente @relation(fields: [pointDeVenteId], references: [id])
  caisse         Caisse       @relation(fields: [caisseId], references: [id])
  utilisateur    Utilisateur  @relation(fields: [utilisateurId], references: [id])
  client         Client?      @relation(fields: [clientId], references: [id])
  originalSale   Vente?       @relation("SaleRefundLink", fields: [originalSaleId], references: [id])
  refundSales    Vente[]      @relation("SaleRefundLink")
  sessionCaisse  SessionCaisse? @relation(fields: [sessionCaisseId], references: [id])
  lignes         VenteLigne[]
  retours        Retour[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organisationId])
  @@index([dateVente])
  @@index([pointDeVenteId])
  @@index([pointDeVenteId, dateVente])
  @@index([caisseId])
  @@index([utilisateurId])
  @@index([clientId])
  @@index([originalSaleId])
  @@index([sessionCaisseId])
}

model VenteLigne {
  id             Int          @id @default(autoincrement())
  organisationId String
  venteId        Int
  produitId      Int
  varianteId     Int?
  quantite       Float
  prixUnitaire   Decimal      @db.Decimal(10, 2)
  sousTotal      Decimal      @db.Decimal(10, 2)
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  vente          Vente        @relation(fields: [venteId], references: [id], onDelete: Cascade)
  produit        Produit      @relation(fields: [produitId], references: [id])
  variante       ProduitVariante? @relation(fields: [varianteId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organisationId])
  @@index([venteId])
  @@index([produitId])
  @@index([varianteId])
}

model Retour {
  id             Int          @id @default(autoincrement())
  organisationId String
  numero         String
  venteId        Int?
  produitId      Int
  varianteId     Int?
  quantite       Float
  montant        Decimal      @default(0) @db.Decimal(10, 2)
  raison         String?
  createdAt      DateTime     @default(now())
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  vente          Vente?       @relation(fields: [venteId], references: [id], onDelete: Cascade)
  produit        Produit      @relation(fields: [produitId], references: [id])
  variante       ProduitVariante? @relation(fields: [varianteId], references: [id])

  @@unique([organisationId, numero])
  @@index([organisationId])
  @@index([numero])
  @@index([venteId])
  @@index([produitId])
  @@index([varianteId])
}

model Charge {
  id             Int                @id @default(autoincrement())
  organisationId String
  pointDeVenteId Int
  utilisateurId  Int
  titre          String
  categorie      ChargeCategorie
  montant        Decimal            @db.Decimal(10, 2)
  dateCharge     DateTime           @default(now())
  modePaiement   ChargeModePaiement @default(ESPECE)
  description    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organisation   Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  pointDeVente   PointDeVente       @relation(fields: [pointDeVenteId], references: [id])
  utilisateur    Utilisateur        @relation(fields: [utilisateurId], references: [id])

  @@index([organisationId])
  @@index([pointDeVenteId])
  @@index([utilisateurId])
  @@index([dateCharge])
  @@index([categorie])
  @@index([organisationId, pointDeVenteId, dateCharge])
}

model Achat {
  id             Int          @id @default(autoincrement())
  organisationId String
  numeroAchat    String       @unique
  compteFournisseurId Int
  fournisseurId  Int?
  dateAchat      DateTime     @default(now())
  modeReglement  AchatModeReglement
  dateReglement  DateTime?
  numeroCheque   String?
  observations   String?
  totalHT        Decimal      @db.Decimal(10, 2)
  totalTVA       Decimal      @db.Decimal(10, 2)
  totalTTC       Decimal      @db.Decimal(10, 2)
  pointDeVenteId Int
  statut         AchatStatut  @default(ENREGISTRE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  compteFournisseur Compte    @relation("AchatCompteFournisseur", fields: [compteFournisseurId], references: [id])
  fournisseur    Fournisseur? @relation(fields: [fournisseurId], references: [id])
  pointDeVente   PointDeVente @relation(fields: [pointDeVenteId], references: [id])
  lignes         AchatLigne[]
  avoirsFournisseur AvoirFournisseur[]

  @@index([organisationId])
  @@index([compteFournisseurId])
  @@index([fournisseurId])
  @@index([pointDeVenteId])
  @@index([createdAt])
}

model AchatLigne {
  id             Int          @id @default(autoincrement())
  organisationId String
  achatId        Int
  produitId      Int
  varianteId     Int?
  quantite       Int
  prixAchatUnitaireHT Decimal  @db.Decimal(10, 2)
  tauxTVA        Decimal      @db.Decimal(5, 2)
  montantTVA     Decimal      @db.Decimal(10, 2)
  totalHT        Decimal      @db.Decimal(10, 2)
  totalTTC       Decimal      @db.Decimal(10, 2)
  prixDetail     Decimal      @db.Decimal(10, 2)
  prixGros       Decimal      @db.Decimal(10, 2)
  prixMiniGros   Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  achat          Achat        @relation(fields: [achatId], references: [id], onDelete: Cascade)
  produit        Produit      @relation(fields: [produitId], references: [id])
  variante       ProduitVariante? @relation(fields: [varianteId], references: [id])

  @@index([organisationId])
  @@index([achatId])
  @@index([produitId])
  @@index([varianteId])
  @@map("AchatItem")
}

model Avoir {
  id             Int          @id @default(autoincrement())
  organisationId String
  numeroAvoir    String
  compteClientId Int
  pointDeVenteId Int
  dateAvoir      DateTime     @default(now())
  motif          String?
  total          Decimal      @db.Decimal(10, 2)
  statut         AvoirStatut  @default(ENREGISTRE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  compteClient   Compte       @relation("AvoirCompteClient", fields: [compteClientId], references: [id])
  pointDeVente   PointDeVente @relation(fields: [pointDeVenteId], references: [id])
  lignes         AvoirLigne[]

  @@unique([organisationId, numeroAvoir])
  @@index([organisationId])
  @@index([compteClientId])
  @@index([pointDeVenteId])
  @@index([dateAvoir])
  @@index([statut])
}

model AvoirLigne {
  id             Int          @id @default(autoincrement())
  organisationId String
  avoirId        Int
  produitId      Int
  quantite       Int
  prixUnitaire   Decimal      @db.Decimal(10, 2)
  totalLigne     Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  avoir          Avoir        @relation(fields: [avoirId], references: [id], onDelete: Cascade)
  produit        Produit      @relation(fields: [produitId], references: [id])

  @@index([organisationId])
  @@index([avoirId])
  @@index([produitId])
}

model AvoirFournisseur {
  id                  Int                    @id @default(autoincrement())
  organisationId      String
  numero              String
  compteFournisseurId Int
  achatId             Int?
  pointDeVenteId      Int
  date                DateTime               @default(now())
  total               Decimal                @db.Decimal(10, 2)
  statut              AvoirFournisseurStatut @default(BROUILLON)
  motif               String?
  compensationMode    CompensationMode
  commentaire         String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  organisation        Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  compteFournisseur   Compte                 @relation("AvoirFournisseurCompte", fields: [compteFournisseurId], references: [id])
  achat               Achat?                 @relation(fields: [achatId], references: [id])
  pointDeVente        PointDeVente           @relation(fields: [pointDeVenteId], references: [id])
  lignes              AvoirFournisseurLigne[]

  @@unique([organisationId, numero])
  @@index([organisationId])
  @@index([compteFournisseurId])
  @@index([achatId])
  @@index([pointDeVenteId])
  @@index([date])
  @@index([statut])
}

model AvoirFournisseurLigne {
  id                 Int               @id @default(autoincrement())
  organisationId     String
  avoirFournisseurId Int
  produitId          Int
  quantite           Int
  prixAchat          Decimal           @db.Decimal(10, 2)
  sousTotal          Decimal           @db.Decimal(10, 2)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organisation       Organisation      @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  avoirFournisseur   AvoirFournisseur  @relation(fields: [avoirFournisseurId], references: [id], onDelete: Cascade)
  produit            Produit           @relation(fields: [produitId], references: [id])

  @@index([organisationId])
  @@index([avoirFournisseurId])
  @@index([produitId])
}
