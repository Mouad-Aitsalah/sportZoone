generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleUtilisateur {
  ADMIN
  EMPLOYE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StockMovementType {
  IN
  CORRECTION
  SALE
  CANCEL
  RETURN
}

model PointDeVente {
  id             Int             @id @default(autoincrement())
  nom            String
  adresse        String?
  telephone      String?
  utilisateurs   Utilisateur[]
  caisses        Caisse[]
  stocks         Stock[]
  stockMovements StockMovement[]
  ventes         Vente[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Utilisateur {
  id             Int             @id @default(autoincrement())
  nom            String
  email          String          @unique
  motDePasse     String
  role           RoleUtilisateur @default(EMPLOYE)
  estActif       Boolean         @default(true)
  approvalStatus ApprovalStatus  @default(PENDING)
  pointDeVenteId Int?
  pointDeVente   PointDeVente?   @relation(fields: [pointDeVenteId], references: [id])
  caisseId       Int?
  caisse         Caisse?         @relation(fields: [caisseId], references: [id])
  ventes         Vente[]
  loginApprovalRequests LoginApprovalRequest[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([pointDeVenteId])
  @@index([caisseId])
  @@index([approvalStatus])
}

model LoginApprovalRequest {
  id         Int            @id @default(autoincrement())
  userId      Int
  email       String
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  approvedAt  DateTime?
  user        Utilisateur    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Caisse {
  id             Int           @id @default(autoincrement())
  nom            String
  code           String        @unique
  pointDeVenteId Int
  estActive      Boolean       @default(true)
  pointDeVente   PointDeVente  @relation(fields: [pointDeVenteId], references: [id], onDelete: Cascade)
  utilisateurs   Utilisateur[]
  ventes         Vente[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([pointDeVenteId, nom])
  @@index([pointDeVenteId])
  @@index([estActive])
}

model Fournisseur {
  id        Int       @id @default(autoincrement())
  nom       String
  email     String?   @unique
  telephone String?
  adresse   String?
  produits  Produit[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Produit {
  id            Int          @id @default(autoincrement())
  codeBarres    String       @unique
  nom           String
  categorie     String
  prixAchat     Decimal      @db.Decimal(10, 2)
  prixVente     Decimal      @db.Decimal(10, 2)
  seuilMinimum  Int          @default(0)
  estActif      Boolean      @default(true)
  fournisseurId Int?
  fournisseur   Fournisseur? @relation(fields: [fournisseurId], references: [id])
  stocks        Stock[]
  stockMovements StockMovement[]
  lignesVente   VenteLigne[]
  retours       Retour[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([categorie])
  @@index([fournisseurId])
}

model Client {
  id           Int      @id @default(autoincrement())
  numeroClient Int      @unique
  nom          String
  telephone    String?
  email        String?
  credit       Decimal  @default(0) @db.Decimal(10, 2)
  estActif     Boolean  @default(true)
  ventes       Vente[]
  paiements    PaiementClient[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([nom])
  @@index([estActif])
}

model PaiementClient {
  id        Int      @id @default(autoincrement())
  clientId  Int
  montant   Decimal  @db.Decimal(10, 2)
  note      String?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdAt])
}

model Stock {
  id             Int          @id @default(autoincrement())
  produitId      Int
  pointDeVenteId Int
  quantite       Int          @default(0)
  produit        Produit      @relation(fields: [produitId], references: [id], onDelete: Cascade)
  pointDeVente   PointDeVente @relation(fields: [pointDeVenteId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([produitId, pointDeVenteId])
  @@index([produitId])
  @@index([pointDeVenteId])
}

model StockMovement {
  id             Int               @id @default(autoincrement())
  produitId      Int
  pointDeVenteId Int
  quantite       Int
  type           StockMovementType
  reason         String?
  createdAt      DateTime          @default(now())
  produit        Produit           @relation(fields: [produitId], references: [id], onDelete: Cascade)
  pointDeVente   PointDeVente      @relation(fields: [pointDeVenteId], references: [id], onDelete: Cascade)

  @@index([produitId])
  @@index([pointDeVenteId])
  @@index([type])
  @@index([createdAt])
}

model Vente {
  id             Int          @id @default(autoincrement())
  numeroTicket   String       @unique
  total          Decimal      @db.Decimal(10, 2)
  paymentMethod  String       @default("cash")
  status         String       @default("completed")
  dateVente      DateTime     @default(now())
  pointDeVenteId Int
  caisseId       Int
  utilisateurId  Int
  clientId       Int?
  pointDeVente   PointDeVente @relation(fields: [pointDeVenteId], references: [id])
  caisse         Caisse       @relation(fields: [caisseId], references: [id])
  utilisateur    Utilisateur  @relation(fields: [utilisateurId], references: [id])
  client         Client?      @relation(fields: [clientId], references: [id])
  lignes         VenteLigne[]
  retours        Retour[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([dateVente])
  @@index([pointDeVenteId])
  @@index([pointDeVenteId, dateVente])
  @@index([caisseId])
  @@index([utilisateurId])
  @@index([clientId])
}

model VenteLigne {
  id           Int      @id @default(autoincrement())
  venteId      Int
  produitId    Int
  quantite     Int
  prixUnitaire Decimal  @db.Decimal(10, 2)
  sousTotal    Decimal  @db.Decimal(10, 2)
  vente        Vente    @relation(fields: [venteId], references: [id], onDelete: Cascade)
  produit      Produit  @relation(fields: [produitId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([venteId])
  @@index([produitId])
}

model Retour {
  id        Int      @id @default(autoincrement())
  venteId   Int
  produitId Int
  quantite  Int
  raison    String?
  createdAt DateTime @default(now())
  vente     Vente    @relation(fields: [venteId], references: [id], onDelete: Cascade)
  produit   Produit  @relation(fields: [produitId], references: [id])

  @@index([venteId])
  @@index([produitId])
}
